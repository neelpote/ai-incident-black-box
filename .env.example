# Demo mode: deterministic simulated receipt, no credentials needed
FILECOIN_STORAGE_MODE=mock

# Real Filecoin Pin mode: use a funded wallet on Calibration before deploying.
# FILECOIN_STORAGE_MODE=filecoin-pin
FILECOIN_NETWORK=calibration

# Never commit a real private key. Use a funded throwaway wallet for demos.
# It needs Calibration tFIL for gas and test USDFC for Filecoin Pin storage payments.
PRIVATE_KEY=

# Filecoin Pin add uses --auto-fund. These optional limits control the USDFC
# Filecoin Pay balance it maintains before an upload.
FILECOIN_MIN_RUNWAY_DAYS=30
FILECOIN_MAX_BALANCE_USDFC=5.00

# Optional custom IPFS gateway for retrieval verification
FILECOIN_GATEWAY_URL=https://ipfs.io

# Optional override when not using the local node_modules binary
FILECOIN_PIN_COMMAND=
